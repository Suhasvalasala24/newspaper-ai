{
  "manifest_version": 3,
  "name": "News AI Assistant",
  "version": "1.0.0",
  "description": "AI-powered assistant for your newspaper — summarize, ask, and listen to today's news.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://*.eenadu.net/*",
    "https://*.thehindu.com/*",
    "https://*.deccanchronicle.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.eenadu.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "widget/newsai-widget.js",
        "widget/newsai-widget.css",
        "widget/newsai-config-loader.js",
        "widget/newsai-content.js",
        "configs/eenadu.json"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
